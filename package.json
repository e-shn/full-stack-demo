{
  "name": "fullstack-demo",
  "version": "1.0.0",
  "description": "Simple full-stack demo app for testing",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "npx playwright test",
    "test:e2e:ci": "npx playwright test --workers=1 --retries=0",
    "test:e2e:concurrent": "npx playwright test --workers=1 --retries=0 --repeat-each=2",
    "test:e2e:prepush": "npm run test:unit && npm run test:e2e:concurrent",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/pre-push",
    "test:unit": "node --test utils/dateFormat.test.js",
    "test:bdd": "npx cucumber-js"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@cucumber/cucumber": "^12.2.0",
    "@qflow/core": "^0.1.1",
    "@types/node": "^25.6.0"
  }
}
